# ==========================================
# WorkSphere - Environment Variables Template
# ==========================================

# ----------------------------
# Frontend (Client) Variables
# ----------------------------
VITE_API_URL=http://localhost:5000/api/v1

# ----------------------------
# Backend (Server) Variables
# ----------------------------
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/worksphere?retryWrites=true&w=majority

# JWT Configurations
JWT_SECRET=super_secret_jwt_access_token_key_change_me_in_production_12345
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_change_me_in_production_54321

# SMTP Configuration (Emails)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Cloudinary Configuration (File Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
